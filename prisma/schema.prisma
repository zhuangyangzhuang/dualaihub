generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  credits       Credit?
  transactions  Transaction[]
  aiHistory     AIHistory[]
  pointTransactions PointTransaction[]
  pointsConsumptionLogs PointsConsumptionLog[]
  videoUsages   UserVideoUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  BASIC
  PRO
  BUSINESS
}

enum PointTransactionType {
  PURCHASE
  USAGE
  REFUND
  BONUS
  EXPIRATION
}

model PointTransaction {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  type        PointTransactionType
  description String?
  createdAt   DateTime               @default(now())
}

model Credit {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount             Int      @default(0)
  points             Int      @default(0)                   // 永久积分（购买/充值获得，永不过期）
  monthlyPoints      Int      @default(0)                   // 月度积分（会员每月发放）
  shortDramaQuota    Int      @default(0)                   // 月度短剧免费配额
  shortDramaUsedThisMonth Int      @default(0)               // 本月已使用的短剧配额
  dailyUsed          Int      @default(0)                   // 每日试用积分使用量（FREE用户）
  videoUsedThisMonth Int      @default(0)
  lastVideoReset     DateTime @default(now())
  lastReset          DateTime @default(now())
  lastPointsReset    DateTime @default(now())               // 上次月度积分发放时间
  lastDailyReset     DateTime @default(now())               // 上次每日积分重置时间
  updatedAt          DateTime @updatedAt
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            TransactionType
  amount          Decimal           @db.Decimal(10, 2)
  currency        String            @default("USD")
  status          TransactionStatus
  paymentMethod   String?
  externalId      String?
  planId          String?
  creditsGranted  Int?
  description     String?
  createdAt       DateTime          @default(now())
}

enum TransactionType {
  SUBSCRIPTION
  ONE_TIME
  USDT
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model AIHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceType String
  model       String
  prompt      String   @db.Text
  result      String?  @db.Text
  creditsUsed Int
  status      String   @default("completed")
  createdAt   DateTime @default(now())
}

model Settings {
  id           String  @id @default("global")
  usdtAddress  String?
  usdtEnabled  Boolean @default(false)
  maintenance  Boolean @default(false)
  updatedAt    DateTime @updatedAt
}

model AIConfig {
  id        String  @id @default(cuid())
  provider  String  @unique
  apiKey    String
  enabled   Boolean @default(true)
  priority  Int     @default(0)
  rateLimit Int     @default(100)
  updatedAt DateTime @updatedAt
}

model AIServicePricing {
  id               String   @id @default(cuid())
  serviceType      String
  modelId          String   @unique
  baseCost         Decimal  @db.Decimal(10, 4)
  profitMultiplier Decimal  @default(1.0)
  isEnabled        Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

model UserVideoUsage {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month      Int
  year       Int
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, month, year])
}

// 积分消费日志 - 详细记录所有消费
model PointsConsumptionLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceType    String                       // 服务类型（TEXT_BASIC, IMAGE_HIGH_END等）
  modelId        String                       // 使用模型ID
  pointsUsed     Int                          // 消耗积分数量
  inputTokens    Int?                         // 输入token数（可选）
  outputTokens   Int?                         // 输出token数（可选）
  deductedFrom   String                       // 扣减来源（MONTHLY/PERMANENT/QUOTA/TRIAL）
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, serviceType])
}
